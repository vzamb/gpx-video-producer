<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <!-- Cloud Backup (Android 12+) -->
    <cloud-backup>
        <exclude domain="sharedpref" path="strava_tokens.xml" />
        <exclude domain="file" path="datastore/strava_tokens.preferences_pb" />
    </cloud-backup>
    <!-- Device-to-device transfer (Android 12+) -->
    <device-transfer>
        <exclude domain="sharedpref" path="strava_tokens.xml" />
        <exclude domain="file" path="datastore/strava_tokens.preferences_pb" />
    </device-transfer>
</data-extraction-rules>
